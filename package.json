{
	"name": "introduction-to-propositional-logic",
	"private": true,
	"version": "0.1.0-alpha",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "pnpm run test:unit && pnpm run test:e2e",
		"test:unit": "pnpm run db:reset:test && CI=1 vitest run; EXIT_CODE=$?; pnpm run db:stop:test; exit $EXIT_CODE",
		"test:e2e": "pnpm run build && pnpm run db:reset:test && CI=1 dotenv -e .env.test -- playwright test --reporter=line; EXIT_CODE=$?; pnpm run db:stop:test; exit $EXIT_CODE",
		"db:start:dev": "docker compose --env-file .env.development up plcourse-db -d --wait",
		"db:stop:dev": "docker compose --env-file .env.development stop plcourse-db",
		"db:reset:dev": "docker compose --env-file .env.development down -v && pnpm run db:start:dev && pnpm run db:migrate:dev && pnpm run db:seed:dev",
		"db:start:test": "docker compose up db-test -d --wait",
		"db:stop:test": "docker compose rm -sf db-test",
		"db:reset:test": "pnpm run db:stop:test && pnpm run db:start:test && pnpm run db:migrate:test && pnpm run db:seed:test",
		"db:migrate:make": "kysely migrate make",
		"db:migrate:dev": "dotenv -e .env.development -- kysely migrate latest",
		"db:migrate:test": "dotenv -e .env.test -- kysely migrate latest",
		"db:migrate:prod": "kysely migrate latest",
		"db:migrate:rollback:dev": "dotenv -e .env.development -- kysely migrate rollback",
		"db:migrate:rollback:prod": "kysely migrate rollback",
		"db:seed:dev": "dotenv -e .env.development -- tsx src/lib/scripts/sync-curriculum.ts",
		"db:seed:test": "dotenv -e .env.test -- tsx src/lib/scripts/sync-curriculum.ts",
		"db:seed:prod": "tsx src/lib/scripts/sync-curriculum.ts",
		"storybook": "storybook dev -p 6006"
	},
	"dependencies": {
		"@lucide/svelte": "^0.561.0",
		"@sveltejs/kit": "^2.55.0",
		"@xyflow/svelte": "^1.5.1",
		"better-auth": "^1.5.5",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"gray-matter": "^4.0.3",
		"hast-util-sanitize": "^5.0.2",
		"js-yaml": "^4.1.1",
		"katex": "^0.16.39",
		"kysely": "^0.28.14",
		"kysely-ctl": "^0.20.0",
		"nanoid": "^5.1.7",
		"pg": "^8.20.0",
		"rehype-katex": "^7.0.1",
		"rehype-sanitize": "^6.0.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-math": "^6.0.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"svelte": "^5.54.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"ts-fsrs": "^5.3.1",
		"tsx": "^4.21.0",
		"unified": "^11.0.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.0.2",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^9.39.4",
		"@iconify-json/mingcute": "^1.2.7",
		"@iconify/tailwind4": "^1.2.3",
		"@internationalized/date": "^3.12.0",
		"@playwright/test": "^1.58.2",
		"@storybook/addon-a11y": "^10.3.1",
		"@storybook/addon-docs": "^10.3.1",
		"@storybook/addon-svelte-csf": "^5.0.12",
		"@storybook/addon-vitest": "^10.3.1",
		"@storybook/sveltekit": "^10.3.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/js-yaml": "^4.0.9",
		"@types/katex": "^0.16.8",
		"@types/mdast": "^4.0.4",
		"@types/node": "^25.5.0",
		"@types/pg": "^8.18.0",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "4.0.18",
		"dotenv-cli": "^11.0.0",
		"eslint": "^9.39.4",
		"eslint-plugin-storybook": "^10.3.1",
		"eslint-plugin-svelte": "^3.15.2",
		"eslint-plugin-yml": "^3.3.1",
		"globals": "^17.4.0",
		"knip": "^5.88.1",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.3.1",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.2.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.1",
		"unist-util-visit": "^5.1.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.1.0"
	}
}
