# Base URL for the app.
# Local dev example: http://localhost:5173
# Production example: https://plcourse.moaaza.com
APP_URL=https://plcourse.moaaza.com

# PostgreSQL connection values.
# Local dev often uses localhost:5432.
# In Docker/Kamal deploys, host is usually the DB service/container name.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
# Generate a strong password:
# openssl rand -base64 24
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=plcourse_db

# Better Auth signing secret:
# openssl rand -base64 32
BETTER_AUTH_SECRET=your_better_auth_secret

# GitHub OAuth app credentials:
# https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth credentials:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub Personal Access Token (classic) for GHCR push/pull.
# Required scope: write:packages
# https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token

# Umami app secret:
# openssl rand -base64 32
UMAMI_APP_SECRET=your_umami_app_secret

# Umami database URL:
# Used by the Umami analytics container to connect to PostgreSQL.
UMAMI_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/umami_db
